# Required by every example
ACAS_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
ACAS_RESOURCE_GROUP=rg-acas-dev
ACAS_LOCATION=westus2
ACAS_SANDBOX_GROUP=acas-sandboxes

# Optional — warm pool
ACAS_WARM_SIZE=0
ACAS_WARM_DISK=python-3.13

# Optional — durable session id pairing (see example 05)
# ACAS_SESSION_ID=
# ACAS_SESSION_STORE_PATH=.acas/sessions.json

# Optional — telemetry tuning
# ENABLE_SENSITIVE_DATA=false   # set "true" to record stdin / stdout snippets on spans

# Required by example 07
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Required by example 08
AZURE_AI_PROJECT_ENDPOINT=https://your-project.cognitiveservices.azure.com/
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5-mini
